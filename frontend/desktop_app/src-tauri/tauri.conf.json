{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "livetalking-pc",
  "version": "0.1.0",
  "identifier": "com.lukeding.livetalking-pc",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist",
    "env": {
      "VITE_API_HOST": "192.168.1.132",
      "VITE_API_PORT": "8011",
      "VITE_API_BASE_URL": "http://192.168.1.132:8011"
    }
  },
  "app": {
    "windows": [
      {
        "title": "livetalking-pc",
        "width": 1280,
        "height": 960,
        "dragDropEnabled": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "entitlements": "Entitlements.plist",
      "infoPlist": "Info.plist"
    },
    "windows": {
      "wix": {
        "language": "zh-CN"
      },
      "nsis": {
        "languages": ["SimpChinese"],
        "displayLanguageSelector": false
      },
      "webviewInstallMode": {
        "type": "embedBootstrapper"
      }
    }
  }
}
