{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window with media device access",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "core:window:allow-start-dragging",
    "core:window:allow-maximize",
    "core:window:allow-minimize",
    "core:window:allow-close",
    "core:window:allow-center",
    "core:window:allow-set-size",
    "opener:default",
    "core:default",
    "core:webview:allow-webview-close",
    "core:webview:allow-webview-create",
    "core:webview:allow-webview-create-webview-window",
    "core:webview:allow-webview-create-webview",
    "core:webview:allow-webview-position",
    "core:webview:allow-webview-size",
    "core:webview:allow-webview-print"
  ]
}
