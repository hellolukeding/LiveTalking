# LiveTalking Docker 环境配置示例
# 复制此文件为 .env 并修改配置

# ==================== LLM 配置 ====================
# LLM 模型选择
LLM_MODEL=gpt-3.5-turbo

# OpenAI API 配置
OPEN_AI_URL=https://api.openai.com/v1
OPEN_AI_API_KEY=your-openai-api-key-here

# ==================== TTS 配置 ====================
# TTS 引擎选择: edge, doubao, tencent, azure, fish, sovits, cosyvoice, indextts2, xtts
TTS_TYPE=edge

# Edge TTS (免费，默认)
EDGE_TTS_VOICE=zh-CN-YunxiNeural

# 豆包 TTS (需要配置)
DOUBAO_APPID=your-doubao-appid
DOUBAO_ACCESS_TOKEN=your-doubao-access-token
DOUBAO_SECRET_KEY=your-doubao-secret-key
DOUBAO_TOKEN=your-doubao-token
DOUBAO_RESOURCE_ID=seed-tts-1.0
DOUBAO_VOICE_ID=zh_female_tianxinxiaomei_emo_v2_mars_bigtts

# 腾讯 TTS (需要配置)
TENCENT_APPID=your-tencent-appid
TENCENT_SECRET_ID=your-tencent-secret-id
TENCENT_SECRET_KEY=your-tencent-secret-key
TENCENT_VOICE_TYPE=1001

# Azure TTS (需要配置)
AZURE_SPEECH_KEY=your-azure-speech-key
AZURE_TTS_REGION=your-azure-region

# 本地 TTS 服务
TTS_SERVER=http://127.0.0.1:9880

# ==================== ASR 配置 ====================
# ASR 引擎选择: tencent, funasr, huber, lip
ASR_TYPE=lip

# 腾讯 ASR (需要配置)
TENCENT_ASR_SECRET_ID=your-tencent-asr-secret-id
TENCENT_ASR_SECRET_KEY=your-tencent-asr-secret-key

# ==================== 其他配置 ====================
# 帧率
FPS=25

# 日志级别: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# 最大会话数
MAX_SESSION=5

# Web 监听端口
LISTEN_PORT=8010

# 音频处理配置
AUDIO_HQ_PROCESSOR=1
AUDIO_CROSSFADE=64
AUDIO_CUTOFF=6000.0
