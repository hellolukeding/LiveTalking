# LiveTalking Backend Dockerfile
# 使用 NVIDIA CUDA 基础镜像以支持 GPU 加速
# 从 Docker Hub 拉取，而不是 nvcr.io (需要认证)
ARG BASE_IMAGE=nvidia/cuda:11.8.0-cudnn8-devel-ubuntu22.04
FROM $BASE_IMAGE

# 设置工作目录
WORKDIR /app

# 设置环境变量
ENV PYTHONUNBUFFERED=1 \
    PYTHONDONTWRITEBYTECODE=1 \
    DEBIAN_FRONTEND=noninteractive \
    PIP_NO_CACHE_DIR=1 \
    PIP_DISABLE_PIP_VERSION_CHECK=1

# 安装系统依赖
RUN apt-get update && apt-get install -y --no-install-recommends \
    python3.10 \
    python3-pip \
    python3-dev \
    git \
    wget \
    curl \
    vim \
    ffmpeg \
    libsm6 \
    libxext6 \
    libxrender-dev \
    libgl1-mesa-glx \
    libglib2.0-0 \
    build-essential \
    && rm -rf /var/lib/apt/lists/*

# 创建软链接
RUN ln -sf /usr/bin/python3.10 /usr/bin/python && \
    ln -sf /usr/bin/pip3 /usr/bin/pip

# 升级 pip
RUN pip install --upgrade pip setuptools wheel

# 复制 requirements.txt
COPY requirements.txt .

# 安装 Python 依赖
RUN pip install -r requirements.txt

# 安装额外的依赖（从 pyproject.toml）
RUN pip install python-dotenv httpx pydub requests websocket-client

# 复制项目文件
COPY . .

# 下载模型文件（如果需要）
# RUN python scripts/download_models.py

# 暴露端口
EXPOSE 8010

# 设置环境变量
ENV PYTHONPATH=/app:/app/src:/app/src/core:/app/src/llm:/app/src/utils

# 健康检查
HEALTHCHECK --interval=30s --timeout=10s --start-period=60s --retries=3 \
    CMD curl -f http://localhost:8010/ || exit 1

# 启动命令
CMD ["python", "-u", "src/main/start_quick_fixed.py"]
